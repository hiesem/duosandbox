{
  "name": "DuoSandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "NODE_VERSION": "20",
      "INSTALL_CLAUDE": "false",
      "INSTALL_CODEX": "false",
      "INSTALL_GEMINI": "false"
    }
  },
  // Protection here is isolation, NOT a firewall -- the network is fully open.
  //   --cap-drop=ALL + no-new-privileges : container can't gain host privileges
  //   --pids-limit + --init              : an accidental fork bomb can't wedge the host
  //   --memory / --cpus (commented)      : bound resource use; uncomment + tune to taste
  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges",
    "--pids-limit=1024",
    "--init"
    // , "--memory=8g", "--cpus=4"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "customizations": {
    "vscode": {
      // LLM- and language-agnostic: nothing baked in. Add e.g. "anthropic.claude-code"
      // (and your language extensions) per project if you want them.
      "extensions": []
    }
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspace",
  // The ONLY host path the container can see. Everything else on your machine is invisible.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "mounts": [
    // Persists LLM login/config if you add a CLI. Safe to remove if unused.
    "source=duosandbox-config,target=/home/node/.claude,type=volume"
  ]
}
